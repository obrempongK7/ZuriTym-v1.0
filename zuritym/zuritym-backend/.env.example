APP_NAME=ZuriTym
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://yourdomain.com

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=zuritym_db
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@zuritym.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=https://yourdomain.com/auth/google/callback

# Firebase (Push Notifications)
FIREBASE_CREDENTIALS=storage/firebase/firebase-credentials.json
FIREBASE_PROJECT_ID=

# ZuriTym App Settings
ZURITYM_REFERRAL_REWARD=50
ZURITYM_MIN_WITHDRAWAL=500
ZURITYM_FRAUD_MAX_ACCOUNTS_PER_IP=2
ZURITYM_FRAUD_MAX_ACCOUNTS_PER_DEVICE=1
ZURITYM_SPIN_DAILY_LIMIT=3
ZURITYM_SCRATCH_DAILY_LIMIT=5

# AdMob
ADMOB_APP_ID=
ADMOB_BANNER_ID=
ADMOB_INTERSTITIAL_ID=
ADMOB_REWARDED_ID=

# AppLovin
APPLOVIN_SDK_KEY=
APPLOVIN_BANNER_ID=
APPLOVIN_INTERSTITIAL_ID=
APPLOVIN_REWARDED_ID=
